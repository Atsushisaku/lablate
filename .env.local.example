# Lablate — 環境変数サンプル
# 実値は `.env.local` にコピーして入力（`.env.local` は gitignore 済み）

# ────────────────────────────────────────────────
# 認証（AWS Cognito）
# ────────────────────────────────────────────────
# 値は AWS 側セットアップ完了後に入力すること。
# 未設定のままでもビルドは通るが、実際のログインフローは動かない。
# 開発中は NEXT_PUBLIC_AUTH_MOCK=1 を立てればモックユーザーでログイン UI を試せる。

NEXT_PUBLIC_COGNITO_USER_POOL_ID=
NEXT_PUBLIC_COGNITO_CLIENT_ID=
NEXT_PUBLIC_COGNITO_DOMAIN=
NEXT_PUBLIC_COGNITO_REGION=ap-northeast-1

# コールバック URL（環境ごとに変える）
#   開発:     http://localhost:3000/auth/callback
#   dev 3001: http://localhost:3001/auth/callback
#   本番:     https://lablate.com/auth/callback
# Cognito の Hosted UI 設定で上記すべてを Callback URL に登録しておくこと。
NEXT_PUBLIC_COGNITO_REDIRECT_URI=http://localhost:3000/auth/callback

# ログアウト後にリダイレクトする URL（Hosted UI の Sign out URL と一致させる）
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ────────────────────────────────────────────────
# 開発用モックモード（1 で有効）
# ────────────────────────────────────────────────
# ON の場合、Cognito を呼ばずに固定のモックユーザーで signIn/signOut する。
# AWS セットアップが完了するまでの UI 動作確認用。
# 本番ビルドでは必ず外すか空にすること。
# NEXT_PUBLIC_AUTH_MOCK=1
